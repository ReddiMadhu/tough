<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service (Windows) web.config for FastAPI + Uvicorn.
  Disables response buffering to allow SSE (Server-Sent Events) to stream
  in real-time through IIS/ARR reverse proxy.
-->
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <add name="PythonHandler" path="*" verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>
    <httpPlatformHandler processPath="%HOME%\python\python.exe"
                         arguments="-m uvicorn api.main:app --host 0.0.0.0 --port %HTTP_PLATFORM_PORT%"
                         stdoutLogEnabled="true"
                         stdoutLogFile="\\?\%HOME%\LogFiles\python"
                         startupTimeLimit="60">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatformHandler>

    <!-- Disable response buffering for SSE streams -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Accel-Buffering" value="no" />
      </customHeaders>
    </httpProtocol>

    <!-- Disable dynamic compression so SSE chunks aren't held -->
    <urlCompression doStaticCompression="true"
                    doDynamicCompression="false" />
  </system.webServer>
</configuration>
